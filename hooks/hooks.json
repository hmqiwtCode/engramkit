{
  "description": "EngramKit session-start context loader, auto-save, and pre-compact hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "engramkit-hook session-start",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "engramkit-hook stop",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "engramkit-hook precompact",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
